  flex-direction: row;
  align-items: center;
  position: relative;
  left: 0rpx;
  top: -85rpx;
}

.filterMenu{
  width: 20vw;
  height: 1vh;
  margin-top: 5px;
}

.filterText{
  width: 20vw;
  height: 1vh;
  margin-top: -40px;
}

.noResultsImage{
  height: 40vh;
