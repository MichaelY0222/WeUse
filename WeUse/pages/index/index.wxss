  background-color: #ececec;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  font-size: 12pt;
  font-weight: bold;
  width: 89%;
  margin: 0 3%; 
  padding: 5px;
  padding-left: 20px;
  text-align: left;
  align-items: center;
  position: relative;
  left: -4rpx;
  top: -92rpx;
}

.heading{
  padding-bottom: 40px;
}

.itemRow{
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  white-space: nowrap;
}

item-tile {
  width: 50%;
}

.itemScroll{
  height: 78vh;
}

.filterView{
