/* pages/me/me.wxss */
/* Top Bar */
.sectionTitle {
  font-size: 36rpx;
  font-weight: bold;
  padding: 0 30rpx 20rpx 30rpx;
}
.profileScroll{
  height: 55vh;
}

/* Footer Section */
#main-menu-footer {
  display: flex;
  flex-direction: column;
  position: absolute;
  bottom: 10px;
  width: 100%;
  padding: 0 16px;
  box-sizing: border-box;
  align-items: center;
}

.main-menu-registration-information {
  font-size: 17px;
  color: var(--secondary);
  margin: 0 31px;
}

#main-menu-registration-button {
  margin-top: 11px;
  color: var(--link);
  font-size: 17px;
}

#version-footer {
  color: var(--secondary);
  display: block;
  text-align: center;
  padding-top: 16px;
  font-size: 17px;
}

/* Profile */
.profileBox {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.profileInfo {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
}

.roleTagMain {
  display: inline-block;
  background: #FFD700;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 10rpx;
  font-size: 22rpx;
}

.verifiedBadge {
  display: flex;
  align-items: center;
  color: #4CAF50;
  font-size: 24rpx;
}

.checkIcon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 6rpx;
}

/* Input Fields */
.inputField {
  margin: 16rpx 30rpx;
  padding: 16rpx;
  border: 3rpx solid #FFD700;
  border-radius: 16rpx;
  background: white;
  display: flex;
  align-items: center;
}

.fieldLabel {
  width: 220rpx;
  font-size: 24rpx;
  color: #333;
}

.inputField input {
  flex: 1;
  font-size: 26rpx;
}

.editIcon {
  width: 32rpx;
  height: 32rpx;
  margin-left: 10rpx;
}

.locked {
  opacity: 0.5;
}

/* Stats */
.statsSection {
  margin: 30rpx;
  border-top: 2rpx solid #ddd;
  border-bottom: 2rpx solid #ddd;
  padding: 20rpx 0;
}

.statRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.goldBtn {
  background: #FFD700;
  border-radius: 12rpx;
  padding: 6rpx 24rpx;
  font-size: 24rpx;
  border: none;
}

.goldBtn.large {
  padding: 20rpx 40rpx;
}

/* Favorites */
.favoritesSection {
  margin: 30rpx;
}

.favHeader {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.starIcon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 10rpx;
}

.tableHeader,
.tableRow {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.tableHeader {
  font-weight: bold;
  border-bottom: 2rpx solid #ccc;
}

.tableRow {
  border-bottom: 1rpx solid #eee;
}

.colName {
  width: 30%;
}

.colSeller {
  width: 30%;
  display: flex;
  align-items: center;
}

.colStatus {
  width: 20%;
  color: #2e7d32;
}

.colAction {
  width: 20%;
  display: flex;
  justify-content: space-around;
}

.avatarMini {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 6rpx;
}

.roleTagSmall {
  background: #eee;
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  margin-left: 6rpx;
}

.iconBtn {
  font-size: 28rpx;
}

.iconBtn.remove {
  color: red;
}