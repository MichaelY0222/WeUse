/* pages/post/post.wxss */
.form-container {
  padding: 30rpx;
}

/* PHOTO SECTION */

.photo-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.main-photo {
  width: 260rpx;
  height: 260rpx;
  border: 4rpx solid #f5b800;
  border-radius: 24rpx;
  background: #fff4cc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.main-photo-icon {
  width: 160rpx;
  height: 160rpx;
}

.main-photo-text {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.side-grid {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.grid-item {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx solid #ccc;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
  background: #fff;
}

.grid-item.empty {
  background: #f0f0f0;
}

.grid-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: -8rpx;
  right: -6rpx;
  width: 40rpx;
  height: 40rpx;
  background: red;
  color: white;
  border-radius: 50%;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.grid-index {
  position: absolute;
  bottom: 6rpx;
  left: 6rpx;
  background: #f5b800;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: bold;
}

/* FIELDS */

.field {
  margin-bottom: 30rpx;
}

.field-label {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  display: block;
}

.input-yellow,
.select-yellow {
  border: 4rpx solid #f5b800;
  border-radius: 16rpx;
  padding: 18rpx;
  font-size: 28rpx;
  background: white;
}

.select-yellow {
  position: relative;
}

.textarea-green {
  width: 94%;
  height: 160rpx;
  border: 4rpx solid #6cc24a;
  border-radius: 16rpx;
  padding: 18rpx;
  font-size: 28rpx;
  background: #f6fff0;
}

/* PRICE */

.price-wrapper {
  display: flex;
  align-items: center;
  border: 4rpx solid #f5b800;
  border-radius: 16rpx;
  padding: 18rpx;
  background: white;
}

.yen {
  font-size: 32rpx;
  font-weight: bold;
  color: #f5b800;
  margin-right: 10rpx;
}

.price-input {
  flex: 1;
  font-size: 28rpx;
  border: none;
}

/* BUTTON */

.post-btn {
  margin-top: 40rpx;
  background: #8de0c9;
  border: 4rpx solid #f5b800;
  border-radius: 24rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: black;
  padding: 20rpx 0;
}